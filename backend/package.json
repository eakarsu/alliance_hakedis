{
  "name": "alliance-crm-backend",
  "version": "1.0.0",
  "description": "Alliance CRM Backend API",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "db:schema": "psql $DATABASE_URL -f db/schema.sql",
    "db:seed": "psql $DATABASE_URL -f db/seed.sql",
    "db:reset": "psql $DATABASE_URL -f db/schema.sql && psql $DATABASE_URL -f db/seed.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.4"
  }
}
